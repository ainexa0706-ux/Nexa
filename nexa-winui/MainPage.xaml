<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Nexa_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nexa_WinUI"
    xmlns:vm="using:Nexa_WinUI.ViewModels">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Nexa" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" Width="130" Margin="20,0,0,0"
                      ItemsSource="{x:Bind ViewModel.Modes}" SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}" />
            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.Status, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.75" />
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Messages}" SelectionMode="None" IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,8" Spacing="4">
                        <TextBlock Text="{Binding Role}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Content}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Text="{x:Bind ViewModel.Draft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Nexaにメッセージを送る" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" />
            <Button Grid.Column="1" Content="停止" Command="{x:Bind ViewModel.CancelCommand}" VerticalAlignment="Bottom" />
            <Button Grid.Column="2" Content="送信" Command="{x:Bind ViewModel.SendCommand}" VerticalAlignment="Bottom" />
        </Grid>
    </Grid>
</Page>
