PORT=8787
HOST=0.0.0.0
OLLAMA_URL=http://127.0.0.1:11434
DATA_DIR=./data
WORKSPACE_ROOT=.

# This build intentionally keeps image generation only.
IMAGE_PROVIDER=local-cinematic-image

# Optional: only needed when you connect cloud APIs or future plugins.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AUTO_ROUTE=true
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CODE_MODEL=gpt-4o-mini

# Public URL used for auth, billing redirects, and cookies.
APP_PUBLIC_URL=http://localhost:8787
SESSION_DAYS=30

# Optional owner lock. If set, only this email can become Nexa Admin.
# If empty, the first created account becomes the owner on first startup.
NEXA_OWNER_EMAIL=

# Real Google OAuth login.
# For this Nexa build, create an OAuth 2.0 Client ID with Application type "Web application".
# Register this redirect URI:
# http://localhost:8787/api/auth/google/callback
# Do not use Application type "Desktop app" unless the OAuth flow is changed to installed-app loopback mode.
# For a deployed Nexa server, replace APP_PUBLIC_URL and GOOGLE_REDIRECT_URI with your HTTPS domain.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Optional Stripe billing. Never commit real secret keys.
# Create recurring Price IDs in Stripe, then paste each price_... value here.
STRIPE_SECRET_KEY=
STRIPE_PLUS_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_STUDIO_PRICE_ID=
# Legacy alias: still accepted as the Pro plan price if STRIPE_PRO_PRICE_ID is empty.
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8787/billing?status=success
STRIPE_CANCEL_URL=http://localhost:8787/billing?status=cancel
